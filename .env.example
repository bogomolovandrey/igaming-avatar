# Anthropic Claude
ANTHROPIC_API_KEY=

# Google Cloud (Speech-to-Text + Vertex AI / Gemini)
# Path inside backend container, mounted as a read-only volume.
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp.json

# TTS model toggle (legacy — used to be Gemini Flash; kept for compatibility)
TTS_MODEL=gemini-3.1-flash-tts-preview

# Classic voice fallback uses Deepgram for STT and Cartesia for TTS.
# Get keys from console.deepgram.com / play.cartesia.ai.
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3-general

CARTESIA_API_KEY=
CARTESIA_MODEL=sonic-2
# Default voice — replace with your preferred Cartesia voice id from
# https://play.cartesia.ai/voices
CARTESIA_VOICE_ID=da05e96d-ca10-4220-9042-d8acef654fa9

# Optional: only used by scripts/generate_portraits.py
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Host ports (container ports stay 3000/8000; remap externally if 3000/8000
# are already taken on your machine).
FRONTEND_PORT=3000
BACKEND_PORT=8000

# CORS origin allowed by backend (comma-separated for multiple)
FRONTEND_ORIGIN=http://localhost:3000

# URLs the frontend uses to talk to backend (baked into Next.js build).
# Match these to FRONTEND_PORT/BACKEND_PORT or to your public domain.
BACKEND_URL=http://localhost:8000
BACKEND_WS_URL=ws://localhost:8000

# Anam live video avatar. API key stays on backend; browser receives only
# short-lived session tokens. Pick avatar/voice IDs in Anam Lab.
ANAM_API_KEY=
ANAM_AVATAR_ID=
ANAM_VOICE_ID=
ANAM_LANGUAGE_CODE=ru
ANAM_LLM_ID=CUSTOMER_CLIENT_V1
ANAM_MAX_SESSION_SECONDS=600
